# === Required API Keys ===
GOOGLE_API_KEY=your-google-api-key-here
PINECONE_API_KEY=your-pinecone-api-key-here

# === Gemini LLM ===
GEMINI_MODEL=gemini-2.0-flash
LLM_TEMPERATURE_RESPONSE=0.1
LLM_TEMPERATURE_PARSING=0

# === Embeddings ===
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=768

# === Pinecone ===
PINECONE_INDEX=receipt-intelligence
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
INDEX_READY_POLL_INTERVAL=5
INDEX_READY_TIMEOUT=120

# === Indexer (batch upsert) ===
UPSERT_BATCH_SIZE=50
UPSERT_MAX_RETRIES=3
UPSERT_BASE_BACKOFF=2.0
UPSERT_VERIFY_ATTEMPTS=6
UPSERT_VERIFY_SLEEP=5

# === Query Parsing ===
# REFERENCE_DATE defaults to today's date (used for relative expressions like "last week")
# REFERENCE_DATE=2026-03-15
DATASET_START_DATE=2023-11-01
DATASET_END_DATE=2024-01-31
DEFAULT_TOP_K=20
SOFT_FILTER_MULTIPLIER=3
METADATA_QUERY_LIMIT=1000

# === Retrieval / Display ===
MAX_DISPLAY_RECEIPTS=10
CONTENT_PREVIEW_LENGTH=200

# === Query Validation ===
MAX_QUERY_CHARS=500
MAX_QUERY_SENTENCES=3

# === Frontend / Streamlit ===
API_BASE_URL=http://localhost:8000
HEALTH_CHECK_TIMEOUT=10.0
QUERY_TIMEOUT=60.0
MAX_CONVERSATION_HISTORY=10

# === Test Runner ===
TEST_SLEEP_BETWEEN=5
